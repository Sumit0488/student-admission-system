{
  "name": "student-admission-system",
  "version": "1.0.0",
  "private": true,
  "description": "Student Admission System — monorepo root",
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "lint:backend": "cd backend  && npx eslint src/ --ext .js  --max-warnings 0",
    "lint:frontend": "cd frontend && npx eslint src/ --ext .jsx,.js --max-warnings 0",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "test:backend": "cd backend  && npm test",
    "test:frontend": "cd frontend && npm test",
    "test": "npm run test:backend && npm run test:frontend",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "@apollo/server": "^4.9.5",
    "@sparticuz/chromium-min": "^143.0.4",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.6",
    "joi": "^17.11.0",
    "json2csv": "^6.0.0-alpha.2",
    "mongoose": "^9.3.3",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "puppeteer-core": "^24.40.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2"
  },
  "lint-staged": {
    "backend/src/**/*.js": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "frontend/src/**/*.{js,jsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "**/*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
