{
  "installCommand": "npm install && cd backend && npm install",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/[...path]" },
    { "source": "/(.*)",   "destination": "/index.html" }
  ]
}
